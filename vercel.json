{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "styling/**", "use": "@vercel/static" },
    { "src": "javascript/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/proxy", "dest": "/api/backend.js" },
    { "src": "/api", "dest": "/api/backend.js" },
    { "src": "/", "dest": "/index.html" }
  ]
}
